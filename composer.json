{
    "name": "invenbill/pro",
    "description": "InvenBill Pro — Enterprise Inventory & Billing SaaS",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "ext-gd": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "dompdf/dompdf": "^3.1",
        "razorpay/razorpay": "^2.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "classmap": [
            "core/",
            "models/",
            "controllers/",
            "repositories/",
            "services/",
            "middleware/",
            "bootstrap/"
        ],
        "files": [
            "core/Helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpstan analyse --level=5 core/ models/ controllers/ services/",
        "cs": "phpcs --standard=PSR12 core/ models/ controllers/ services/"
    }
}
