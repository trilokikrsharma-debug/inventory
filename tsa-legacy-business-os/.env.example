APP_NAME="TSA Legacy Business OS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://tsalegacy.shop

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=central
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tsa_platform
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=
DB_TENANT_HOST=127.0.0.1
DB_TENANT_PORT=3306
DB_TENANT_USERNAME=root
DB_TENANT_PASSWORD=
DB_TENANT_SOCKET=

SESSION_DRIVER=redis
SESSION_LIFETIME=240
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.tsalegacy.shop

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

TENANCY_CENTRAL_DOMAINS=localhost,127.0.0.1,tsalegacy.shop,www.tsalegacy.shop,app.tsalegacy.shop

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

SEED_SUPER_ADMIN_NAME=
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
SEED_TENANT_OWNER_NAME=
SEED_TENANT_OWNER_EMAIL=
SEED_TENANT_OWNER_PASSWORD=

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=asia-south1
GOOGLE_CLOUD_STORAGE_BUCKET=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
